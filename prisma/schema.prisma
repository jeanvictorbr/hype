generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Tabela base da Guilda
model Guild {
  id              String   @id
  autoVoiceConfig AutoVoiceConfig?
  ticketConfig    TicketConfig?
  vipExpiresAt    DateTime?
  vipConfig       VipConfig?
  features        String[] @default([])
  storeItems    StoreItem[]
}
// 📦 MÓDULO: CONFIGURAÇÃO DE CARGOS VIP
model VipConfig {
  guildId   String @id
  guild     Guild  @relation(fields: [guildId], references: [id], onDelete: Cascade)
  // 👇 NOVAS LINHAS DO AGIOTA
  agiotaId      String?   // ID do VIP que ativou o pedágio
  agiotaExpires DateTime? // Até quando o pedágio está ativo (15 min)
  banRequestChannel String?
  roleVip1  String?  // Cargo do Nível 1 (Pista Premium)
  roleVip2  String?  // Cargo do Nível 2 (Camarote)
  roleVip3  String?  // Cargo do Nível 3 (Dono do Baile)
  priceVip1 Float?
  priceVip2 Float?
  priceVip3 Float?
  mpAccessToken String? // O Token do Mercado Pago para receber a grana
}
// ==========================================
// 📦 MÓDULO: HYPE ECONOMY & VIP
// ==========================================

// Perfil global do utilizador (Saldo e VIP)
model HypeUser {
  id            String   @id // ID do Discord do Jogador
  hypeCash      Int      @default(0) // Saldo da moeda virtual
  vipLevel      Int      @default(0) // 0 = Normal, 1 = Nível 1, 2 = Nível 2, 3 = Nível 3
  vipExpiresAt  DateTime?
  lastTimeout   DateTime? // 👇 NOVA LINHA AQUI (Controle do Ditador)
  lastDaily     DateTime?  // 👇 ADICIONA ESTA LINHA AQUI!
  carteira   Int      @default(0) // 👈 ADICIONA ISTO: Dinheiro na mão
  createdAt     DateTime @default(now())
  // Cooldowns Sociais (Independentes)
  lastBeijar   DateTime?
  lastTapa     DateTime?
  lastAbracar  DateTime?
  lastMorder   DateTime?
  lastPat      DateTime?
  lastSocar    DateTime?
  lastCafune   DateTime?
  lastSemanal  DateTime?
  lastMensal   DateTime?
  updatedAt     DateTime @updatedAt
  banRequestsCount Int       @default(0)
  cardNumber       String?   @unique
  banRequestReset  DateTime?
  lastAnnounce     DateTime?
  bio           String?   @default("Membro da família Hype! Use o comando de perfil para mudar este texto.")
  rep           Int       @default(0)
  lastRepGiven  DateTime? 
  profileTheme  String?   @default("default")
  // 👇 NOVOS COOLDOWNS ADICIONADOS AQUI
  lastBlackout     DateTime? // Cooldown do Apagão
  lastMoneyRain    DateTime? // Cooldown da Chuva de Prata
  customRoleId  String?  // 👇 NOVA LINHA AQUI! (ID do cargo que ele criou)
}
// 👇 NOVO MODELO: Cofre de Vendas (Anti-Golpe)
model VipSale {
  id            String   @id @default(uuid())
  guildId       String
  userId        String
  planLevel     Int      // 1, 2 ou 3
  planName      String   // "Camarote", "Dono do Baile"
  price         Float    // Valor total pago
  devShare      Float    // Seus 40%
  clientShare   Float    // Os 60% do dono do servidor
  status        String   @default("PENDING") // PENDING ou APPROVED
  paymentId     String?  // ID da transação no Mercado Pago
  
  createdAt     DateTime @default(now())
  approvedAt    DateTime?
}
// Itens da Lojinha vinculados ao servidor (Guild)
model StoreItem {
  id          String   @id @default(uuid())
  guildId     String
  guild       Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  
  name        String
  description String?
  price       Int
  
  roleId      String?  // Se o item der um cargo automático no Discord, salvamos o ID aqui
  isGameItem  Boolean  @default(false) // Se for true, exige entrega manual/log no Roblox
  
  createdAt   DateTime @default(now())
}
// 📦 MÓDULO: TICKETS (Tickets Ativos)
model ActiveTicket {
  channelId       String   @id // ID do canal de texto do ticket
  ownerId         String       // ID do membro que abriu
  claimerId       String?
  guildId         String       // ID do servidor
}

// 👇 NOVA TABELA: Histórico Permanente para /locticket
model TicketHistory {
  protocol        String   @id // Ex: KODA-1A2B3C
  guildId         String
  ownerId         String
  staffId         String?  // Quem atendeu
  transcriptUrl   String?  // Link do arquivo no Discord (CDN)
  
  rating          Int?     // Nota dada (1-5)
  comment         String?  // Comentário do usuário
  
  createdAt       DateTime @default(now())
  closedAt        DateTime @default(now())
}
// 👇 NOVA TABELA: Estatísticas da Equipe
model StaffStats {
  id              String   @id @default(uuid())
  guildId         String
  staffId         String
  
  ticketsClosed   Int      @default(0) // Total atendimentos
  totalStars      Int      @default(0) // Soma das notas (1-5)
  averageRating   Float    @default(0.0) // Média calculada
  
  lastUpdated     DateTime @updatedAt

  @@unique([guildId, staffId]) // Um registro por staff por servidor
}
// 📦 MÓDULO: AUTO-VOICE (Configurações do Painel /hype)
model AutoVoiceConfig {
  guildId         String   @id
  guild           Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  
  triggerChannel  String?  // ID do Canal gatilho
  tempCategory    String?  // ID da Categoria para as salas
  bypassRoles     String[] // Array com IDs dos cargos que têm Passe Livre nas salas trancadas
}

// 📦 MÓDULO: AUTO-VOICE (Salvar Salas Ativas para não perder no restart da Discloud)
model AutoVoiceRoom {
  channelId       String   @id // ID do canal de voz temporário criado
  ownerId         String       // ID do dono da sala
  guildId         String       // ID do servidor
}

model TicketConfig {
  guildId         String   @id
  guild           Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  
  logChannel      String?
  ticketCategory  String?
  staffRoles      String[]
  
  // Relacionamento com Departamentos
  departments     TicketDepartment[]
  
  // Personalização da Vitrine (Painel Público)
  panelTitle      String   @default("📩 Central de Atendimento")
  panelDescription String  @default("Precisa de suporte? Selecione uma opção abaixo para falar com a nossa equipa.")
  panelFooter     String?  
  panelImage      String?
}

model TicketDepartment {
  id              String       @id @default(uuid())
  guildId         String
  config          TicketConfig @relation(fields: [guildId], references: [guildId], onDelete: Cascade)
  
  label           String       // Ex: Financeiro, Suporte
  description     String?      // Ex: Problemas com pagamentos
  emoji           String?      // Ex: 💰
  
  createdAt       DateTime     @default(now())
}